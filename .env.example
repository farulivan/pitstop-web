# Required for JWT signing/verification (used by middleware + MSW handlers).
# Use any high-entropy string in dev. Rotate in production.
JWT_SECRET=replace-me-with-a-long-random-string

# Backend API base URL. In demo mode, MSW intercepts requests to this host,
# so the value mostly serves as a stable identifier — point it at the real
# Go service when wiring up the live backend.
API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Set to "true" to enable MSW mocks in browser + Node runtimes.
# Required for the Vercel demo deploy and for local development before the
# Go API is reachable.
NEXT_PUBLIC_DEMO_MODE=true
